{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/packages/extension"],
      "outFiles": ["${workspaceFolder}/packages/extension/dist/**/*.js"]
    },
    {
      "name": "Run Web Extension",
      "type": "pwa-extensionHost",
      "debugWebWorkerHost": true,
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension",
        "--extensionDevelopmentKind=web"
      ],
      "outFiles": ["${workspaceFolder}/packages/extension/dist/web/**/*.js"]
    },
    {
      "name": "Run Extension Tests",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension",
        "--extensionTestsPath=${workspaceFolder}/packages/extension/dist/test/suite/index",
        "${workspaceFolder}/packages/extension/workspaceTest.code-workspace"
      ],
      "outFiles": ["${workspaceFolder}/packages/extension/dist/test/**/*.js"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Deno Program",
      "program": "${workspaceFolder}/packages/server/src/server.ts",
      "cwd": "${workspaceFolder}/packages/server",
      "env": {},
      "runtimeExecutable": "deno",
      "runtimeArgs": ["run", "-A", "--unstable-sloppy-imports", "--inspect-wait"],
      "attachSimplePort": 9229
    }
  ]
}
