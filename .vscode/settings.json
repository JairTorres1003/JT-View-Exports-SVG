{
  "js/ts.tsc.autoDetect": "off",

  "cSpell.language": "en,es-ES",

  "search.exclude": {
    "**/dist": true,
    "**/.docusaurus": true
  },

  "biome.enabled": true,
  "prettier.enable": true,
  "eslint.enable": false,

  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.fontLigatures": true,
  "editor.linkedEditing": true,
  "editor.detectIndentation": true,
  "editor.guides.bracketPairs": true,
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.defaultFormatter": "biomejs.biome",
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },

  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },

  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.readonlyInclude": {
    ".lintstagedrc": true,
    ".husky/**": true,
    ".vscode/settings.json": true
  },

  "workbench.tree.enableStickyScroll": true,

  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.tsx": "${capture}.tsx",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, .*",
    "package.nls.json": "package.nls*.json"
  },

  "material-icon-theme.files.associations": {
    "i18n.schema.json": "i18n",
    "l10n.schema.json": "i18n",
    "nls.schema.json": "i18n",
    "tsconfig.types.json": "tsconfig"
  },
  "material-icon-theme.folders.associations": {
    "webview": "client",
    "extension-api": "api",
    "workers": "gh-workflows",
    "vs": "vscode"
  },

  "json.schemas": [
    {
      "fileMatch": ["/packages/extension/l10n/bundle.l10n*.json"],
      "url": "./schemas/l10n.schema.json"
    },
    {
      "fileMatch": ["/packages/extension/package.nls*.json"],
      "url": "./schemas/nls.schema.json"
    },
    {
      "fileMatch": ["/packages/webview/src/i18n/locales/*.json"],
      "url": "./schemas/i18n.schema.json"
    },
    {
      "fileMatch": ["/packages/webview/src/assets/vs/userConfiguration/keybindings.json"],
      "url": "vscode://schemas/keybindings"
    }
  ]
}
