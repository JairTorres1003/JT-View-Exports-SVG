    "packages/webview/src/assets/icons/functionalities/sort-desc.tsx",
    "packages/webview/src/assets/icons/indicators/code-tag.tsx",
    "packages/webview/src/assets/icons/indicators/dashboard.tsx",
    "packages/webview/src/assets/icons/indicators/empty-box.tsx",
    "packages/webview/src/assets/icons/indicators/error.tsx",
    "packages/webview/src/assets/icons/indicators/home.tsx",
    "packages/webview/src/assets/icons/indicators/info.tsx",
