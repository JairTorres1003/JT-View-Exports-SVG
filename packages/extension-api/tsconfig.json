{
  "extends": "../extension/tsconfig.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "../extension/src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../extension/src/*"]
    },
    "declaration": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["../extension/src/**/*"],
  "exclude": ["../extension/src/test/**/*", "node_modules", "dist"]
}
