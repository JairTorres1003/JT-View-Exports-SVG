{
  "name": "jt-view-exports-svg-monorepo",
  "displayName": "View Exports SVG",
  "description": "🚀 The ultimate tool to explore and manage SVG components directly in Visual Studio Code.",
  "keywords": [
    "Extension",
    "Icon assets",
    "Icon management",
    "Javascript",
    "JSX",
    "React",
    "SVG icons",
    "TSX",
    "TypeScript",
    "Visual Studio Code",
    "VSCode"
  ],
  "version": "5.0.0",
  "private": true,
  "license": "MIT",
  "author": "Jair Torres",
  "repository": {
    "type": "git",
    "url": "https://github.com/JairTorres1003/JT-View-Exports-SVG.git"
  },
  "bugs": {
    "url": "https://github.com/JairTorres1003/JT-View-Exports-SVG/issues"
  },
  "homepage": "https://github.com/JairTorres1003/JT-View-Exports-SVG#readme",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "clean": "pnpm -r --parallel clean",
    "build:core": "pnpm -F @jt-view-exports-svg/core run build",
    "test:extension": "pnpm -F jt-view-exports-svg run test",
    "test:web-extension": "pnpm -F jt-view-exports-svg run test:web",
    "clean:extension": "pnpm -F jt-view-exports-svg run clean",
    "watch:extension": "pnpm -F jt-view-exports-svg run watch",
    "build:webview": "pnpm -F @jt-view-exports-svg/webview run build",
    "package:extension": "pnpm -F jt-view-exports-svg run package -o $(pwd)",
    "prepare-readme": "node scripts/prepare-readme.js",
    "prerelease": "npm-run-all lint prepare-readme",
    "release": "npm-run-all clean build:core test:extension clean:extension build:webview package:extension",
    "postrelease": "node scripts/prepare-readme.js --restore",
    "prebuild:extension-api": "node scripts/generate-extension-api.js",
    "build:extension-api": "pnpm -F jt-view-exports-svg run build:api",
    "dev:webview": "concurrently \"pnpm -F @jt-view-exports-svg/server run dev\" \"pnpm -F @jt-view-exports-svg/webview run dev\"",
    "dev:extension": "pnpm -F jt-view-exports-svg run dev",
    "build:extension": "pnpm -F jt-view-exports-svg run compile",
    "setup": "pnpm install && npm-run-all clean build:core build:webview build:extension"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
